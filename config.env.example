# Configuration exemple pour Tubpi
# Copiez ce fichier en config.env et modifiez selon vos besoins
# Les services systemd peuvent charger ce fichier avec EnvironmentFile=

# Configuration caméra
CAMERA_HOST=192.168.1.108
CAMERA_PORT=80
CAMERA_USER=admin
CAMERA_PASSWORD=your_password_here

# Configuration réseau
ETH0_ADDR=192.168.11.28
ETH1_ADDR=192.168.1.30

# Configuration moteur (GPIO BCM)
MOTOR_FORWARD_PIN=20
MOTOR_BACKWARD_PIN=21
MOTOR_PWM_PIN=26

# Capteurs de fin de course (GPIO BCM)
LIMIT_FORWARD_PIN=23
LIMIT_BACKWARD_PIN=24

# Encodeur (GPIO BCM)
ENCODER_A_PIN=17
ENCODER_B_PIN=27
ENCODER_INDEX_PIN=22

# Calibration encodeur
MM_PER_PULSE=0.1

# Options
ENABLE_ENCODER=true
DEBUG_MODE=false

# Ports
ONVIF_GATEWAY_PORT=80
WEBAPP_PORT=5000
